# Digital twin chat (Netlify function -> OpenRouter)
# Set these in the Netlify dashboard (Site configuration -> Environment variables)
# or in a local .env when running `netlify dev`.

# Required — create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Required — any OpenRouter model id (free model below)
OPENROUTER_MODEL=nex-agi/nex-n2-pro:free

# Capy's Quest "Send to Sofina" email (Netlify function -> Resend)
# Required — create a key at https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key-here

# Optional — recipient; defaults to Sofina's inbox if unset
RESEND_TO=sofinajohari.uwealth@gmail.com

# Note: the sender is hardcoded in netlify/functions/send-roadmap.mjs to a
# verified eazylaundry.biz address and is intentionally NOT configurable
# via env. There is no RESEND_FROM variable.
